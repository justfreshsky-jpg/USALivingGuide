# ─── AI Provider Keys (set at least one) ───────────────────────────────────────
# Providers are tried in order; the first one with a configured key is used.

# 1. Groq  https://console.groq.com/keys
GROQ_KEY=

# 2. Cerebras  https://cloud.cerebras.ai/
CEREBRAS_KEY=

# 3. Google AI Studio (Gemini REST — no GCP required)  https://aistudio.google.com/apikey
GEMINI_KEY=

# 4. Cohere  https://dashboard.cohere.com/api-keys
COHERE_KEY=

# 5. Mistral  https://console.mistral.ai/api-keys
MISTRAL_KEY=

# 6. OpenRouter  https://openrouter.ai/keys
OPENROUTER_KEY=

# 7. Hugging Face Inference API  https://huggingface.co/settings/tokens
HF_KEY=

# ─── Flask / Gunicorn ───────────────────────────────────────────────────────────
PORT=8080

# ─── Optional: file logging (leave empty for stdout-only in Docker) ─────────────
# LOG_DIR=logs
